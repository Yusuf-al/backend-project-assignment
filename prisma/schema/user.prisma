model User {
  id             String      @id @default(uuid())

  name           String
  email          String    @unique
  password       String

  contacts       Contact[]

  role            Role @default(USER)
  isActive        Active_Status @default(ACTIVE)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

    @@map("users")
}

enum Active_Status {
    ACTIVE 
    BLOCKED
} 

enum Role {
    USER 
    ADMIN 

}